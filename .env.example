# =============================================================================
# 必須設定
# =============================================================================

# OpenAI API キー（URLからのレシピ取り込み機能に必要）
# https://platform.openai.com/api-keys で取得
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# 任意設定（デフォルト値あり）
# =============================================================================

# Basic 認証のユーザー名（デフォルト: admin）
BASIC_AUTH_USER=admin

# Basic 認証のパスワード（デフォルト: password）
# 本番環境では必ず変更すること
BASIC_AUTH_PASS=password

# JWT 認証のシークレットキー（デフォルト: 32文字のランダム文字列）
JWT_SECRET_KEY=hogefuga
